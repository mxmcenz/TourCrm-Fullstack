# --- DATABASE CONFIG ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=tourcrm_db

# --- ENVIRONMENT ---
ASPNETCORE_ENVIRONMENT=Development

# --- CONNECTION STRING ---
ConnectionStrings__DefaultConnection=Host=db;Port=5432;Database=${POSTGRES_DB};Username=${POSTGRES_USER};Password=${POSTGRES_PASSWORD};

# --- JWT SETTINGS ---
Jwt__Key=your-very-secure-secret-key-here-32-chars
Jwt__Issuer=TourCrm
Jwt__Audience=TourCrmUsers
Jwt__AccessTokenExpirationMinutes=15
Jwt__RefreshTokenExpirationDays=7

# --- EMAIL SETTINGS (SMTP) ---
EmailSettings__Sender=your-email@gmail.com
EmailSettings__AppPassword=your-google-app-password
EmailSettings__SmtpServer=smtp.gmail.com

# --- INITIAL SEED DATA ---
SuperAdmin__Email=admin@test.kz
SuperAdmin__Password=admin

# --- BUSINESS LOGIC (TRIAL) ---
Trial__TariffName=Trial
Trial__Days=30
Trial__MinEmployees=1
Trial__MaxEmployees=10

# --- CORS ---
FrontendOrigins=http://localhost,http://localhost:80,http://localhost:5173
